{
  "name": "antigravity-runner",
  "displayName": "Antigravity Runner",
  "description": "Browse and run Antigravity agents, skills, and workflows.",
  "version": "0.0.1",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:antigravityView",
    "onCommand:antigravity.refresh",
    "onCommand:antigravity.runItem"
  ],
  "main": "./extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "antigravityView",
          "name": "Antigravity"
        }
      ]
    },
    "commands": [
      {
        "command": "antigravity.refresh",
        "title": "Antigravity: Refresh"
      },
      {
        "command": "antigravity.runItem",
        "title": "Antigravity: Run Item"
      }
    ]
  }
}
