# -----------------------------------------------------------------------------
# Local Development Secrets & API Keys
# -----------------------------------------------------------------------------
# DANGER: DO NOT COMMIT THIS FILE TO VERSION CONTROL
# This file contains the sensitive environment variables that correspond
# with the topology mapped out in `config/dev.yaml`.

DB_PASSWORD=dev_local_super_secret_password
REDIS_PASSWORD=dev_redis_cache_key
SESSION_SECRET=dev_cookie_signing_token_8892

# External Integrations (Sandbox/Dev Keys)
PAYMENT_GATEWAY_API_KEY=PAYMENT_GATEWAY_API_HERE
EMAIL_PROVIDER_TOKEN=EMAIL_PROVIDER_TOKEN_HERE

# Auth Issuer Secrets
AUTH_CLIENT_SECRET=oauth_local_dev_secret_xyz

# Render API KEY
RenderApiKey:RENDER_API_HERE
RenderOwnerID:RENDER_OWNERID_HERE
